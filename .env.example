# Discord
DISCORD_TOKEN=
OWNER_USER_ID=

# General
TIMEZONE=America/New_York
HISTORY_LIMIT=10

# LLM backend. Default is the containerized Ollama service (run with --profile ollama).
# For Anthropic (Claude): LLM_BASE_URL=https://api.anthropic.com/v1/   LLM_API_KEY=<sk-ant- key>   LLM_MODEL=claude-sonnet-4-6
# For the gateway profile:  LLM_BASE_URL=http://agentgateway:3000/v1   LLM_MODEL=ollama/llama3.1:8b
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b

# Notion (mcp-tools)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Google Calendar (mcp-tools)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Web search (optional, mcp-tools). Leave blank to disable the web_search tool.
TAVILY_API_KEY=

# Anthropic key (only used by the gateway profile)
ANTHROPIC_API_KEY=

# Grafana Cloud (only used by the metrics/alloy profile)
GRAFANA_PROM_URL=
GRAFANA_PROM_USER=
GRAFANA_PROM_TOKEN=
