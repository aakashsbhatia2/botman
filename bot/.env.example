# Discord (Step 1)
DISCORD_TOKEN=
OWNER_USER_ID=

# LLM backend (Step 2): any OpenAI-compatible endpoint. Fill one set below.
# Ollama (local):  LLM_BASE_URL=http://localhost:11434/v1     LLM_API_KEY=ollama          LLM_MODEL=llama3.1:8b
# agentgateway:    LLM_BASE_URL=http://localhost:3000/v1      LLM_API_KEY=<gateway key>   LLM_MODEL=<model the gateway routes>
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Step 3
TIMEZONE=America/New_York
HISTORY_LIMIT=10

# Where the tools server lives (Step 6)
MCP_SERVER_URL=http://localhost:8080/mcp
